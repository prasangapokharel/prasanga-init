# ============================================================================
# Prasanga UI - Environment Configuration Template
# ============================================================================
# Copy this file to .env and update values for your environment
# This file defines all available configuration options
# ============================================================================

# API Configuration
# ============================================================================
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT=30000
EXPO_PUBLIC_API_RETRY_ATTEMPTS=3

# Theme Configuration
# ============================================================================
EXPO_PUBLIC_THEME_DEFAULT=light
EXPO_PUBLIC_THEME_PERSISTENCE=true

# Feature Flags
# ============================================================================
EXPO_PUBLIC_ENABLE_DEBUG_MODE=false
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false

# App Metadata
# ============================================================================
EXPO_PUBLIC_APP_VERSION=1.3.1
EXPO_PUBLIC_APP_BUILD=1
EXPO_PUBLIC_APP_NAME=Prasanga UI

# Component Configuration
# ============================================================================
# Toast default duration (milliseconds)
EXPO_PUBLIC_TOAST_DURATION=3000

# Modal overlay opacity (0-1)
EXPO_PUBLIC_MODAL_OVERLAY_OPACITY=0.5

# Drawer animation duration (milliseconds)
EXPO_PUBLIC_DRAWER_ANIMATION_DURATION=400

# Database (if applicable)
# ============================================================================
# EXPO_PUBLIC_DB_HOST=localhost
# EXPO_PUBLIC_DB_PORT=5432
# EXPO_PUBLIC_DB_NAME=prasanga
# EXPO_PUBLIC_DB_USER=prasanga
# EXPO_PUBLIC_DB_PASSWORD=

# Logging
# ============================================================================
EXPO_PUBLIC_LOG_LEVEL=info
EXPO_PUBLIC_LOG_PERSISTENCE=false

# Security
# ============================================================================
# EXPO_PUBLIC_JWT_SECRET=your_jwt_secret_here
# EXPO_PUBLIC_ENCRYPTION_KEY=your_encryption_key_here

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env files with sensitive data to version control
# 2. All variables prefixed with EXPO_PUBLIC_ are accessible in the app
# 3. Use non-public variables for sensitive data (requires custom setup)
# 4. Keep .env in .gitignore
# 5. For different environments, create: .env.development, .env.production
# ============================================================================
